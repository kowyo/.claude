{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Glob(**)",
      "LS(**)",
      "Grep(**)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(chmod +x *)",
      "Bash(hf *)",
      "Bash(uv *)",
      "Bash(pnpm *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git push *)",
      "Bash(git status *)",
      "Bash(git -C *)",
      "Bash(git remote *)",
      "Bash(make *)",
      "mcp__chrome-devtools__*",
      "WebSearch",
      "Bash(gh *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(ps *)",
      "Bash(kill *)",
      "Bash(crontab *)",
      "Bash(agent-browser *)"
    ]
  },
  "model": "claude-fable-5",
  "statusLine": {
    "type": "command",
    "command": "sh $HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "effortLevel": "high",
  "autoMemoryEnabled": false,
  "showThinkingSummaries": true,
  "theme": "auto",
  "disableDeepLinkRegistration": "disable",
  "skipWorkflowUsageWarning": true
}